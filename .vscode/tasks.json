{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Local checks: demo_video_ready",
      "type": "shell",
      "command": "bash scripts/demo_video_ready.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "Pytest only (no Ollama)",
      "type": "shell",
      "command": ".venv/bin/pytest tests/ -q",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Serve Revenue Pulse (port 8080)",
      "type": "shell",
      "command": "python3 -m http.server 8080 --directory revenue_pulse",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    }
  ]
}
